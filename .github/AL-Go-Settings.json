{
  "$schema": "https://raw.githubusercontent.com/microsoft/AL-Go/Actions/cdc0cb5199db14e1b257f6b9b0c349e60aa1cc1b/.Modules/settings.schema.json",
  "githubRunner": "windows-latest",
  "doNotPublishApps": true,
  "MicrosoftTelemetryConnectionString": "",
  "type": "PTE",
  "incrementalBuilds": {
    "onPush": true
  },
  "useApproximateVersion": true,
  "conditionalSettings": [
    {
      "settings": {
        "workflowConcurrency": [
          "group: ${{ github.workflow }}-${{ github.ref }}",
          "cancel-in-progress: true"
        ]
      },
      "workflows": [
        "CI/CD"
      ]
    }
  ],
  "githubRunnerShell": "powershell",
  "useCompilerFolder": true,
  "UseProjectDependencies": true,
  "templateUrl": "https://github.com/businesscentralapps/tmptoHSnf-PTE@main",
  "templateSha": "156ee540d4df30e0b881c381d03f03a765036b30"
}
